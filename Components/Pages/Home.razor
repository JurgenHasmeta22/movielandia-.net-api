@page "/"
@inject IMovieService MovieService

<PageTitle>Movielandia – Discover Films</PageTitle>

<!-- ── Hero ──────────────────────────────────────────────────────────────── -->
<section class="relative overflow-hidden py-24 px-6">
    <!-- Ambient glow -->
    <div class="pointer-events-none absolute inset-0
                bg-[radial-gradient(ellipse_80%_50%_at_50%_-10%,rgba(245,158,11,0.10),transparent)]">
    </div>

    <div class="relative max-w-7xl mx-auto">
        <!-- Live badge -->
        <div class="inline-flex items-center gap-2 bg-amber-500/10 border border-amber-500/20
                    rounded-full px-4 py-1.5 mb-6">
            <span class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span>
            <span class="text-amber-400 text-sm font-medium">Now streaming</span>
        </div>

        <!-- Heading -->
        <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-[1.05] max-w-3xl">
            <span class="block text-white">Discover your</span>
            <span class="block bg-gradient-to-r from-amber-400 to-orange-500
                         bg-clip-text text-transparent">
                next favourite film.
            </span>
        </h1>

        <p class="mt-6 text-gray-400 text-lg md:text-xl max-w-xl leading-relaxed">
            Browse thousands of movies. Rate, review, and build your perfect watchlist — all in one place.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-wrap gap-4">
            <a href="/movies"
               class="bg-amber-500 hover:bg-amber-400 active:scale-95 text-black font-bold
                      px-8 py-3.5 rounded-full transition-all duration-200 shadow-lg shadow-amber-500/25">
                Browse All Movies
            </a>
            <a href="/movies?sortBy=dateAired&ascOrDesc=desc"
               class="border border-gray-700 hover:border-gray-500 text-gray-300 hover:text-white
                      px-8 py-3.5 rounded-full transition-all duration-200">
                What's New →
            </a>
        </div>
    </div>
</section>

<!-- ── Latest Releases ────────────────────────────────────────────────────── -->
<section class="max-w-7xl mx-auto px-6 pb-24">
    <div class="flex items-end justify-between mb-8">
        <div>
            <h2 class="text-2xl font-bold text-white">Latest Releases</h2>
            <p class="text-gray-500 text-sm mt-1">The newest films added to the platform</p>
        </div>
        <a href="/movies"
           class="text-amber-400 hover:text-amber-300 text-sm font-medium transition-colors hidden sm:block">
            View all →
        </a>
    </div>

    @if (_loading)
    {
        <!-- Skeleton grid -->
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
            @for (var i = 0; i < 6; i++)
            {
                <div class="rounded-xl bg-gray-800/50 overflow-hidden">
                    <div class="aspect-[2/3] bg-gray-700/60 animate-pulse"></div>
                    <div class="p-3 space-y-2">
                        <div class="h-3 bg-gray-700/60 rounded animate-pulse w-3/4"></div>
                        <div class="h-2 bg-gray-700/60 rounded animate-pulse w-1/2"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (_movies?.Any() == true)
    {
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 animate-fade-in">
            @foreach (var movie in _movies.Take(6))
            {
                <MovieCard Movie="movie" />
            }
        </div>
    }
    else
    {
        <div class="text-center py-16">
            <span class="text-4xl">🎬</span>
            <p class="text-gray-500 mt-4">No movies found — make sure the database is seeded.</p>
        </div>
    }
</section>

@code {
    private IEnumerable<MovieDto>? _movies;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _movies = await MovieService.GetForHomePageAsync();
        _loading = false;
    }
}
