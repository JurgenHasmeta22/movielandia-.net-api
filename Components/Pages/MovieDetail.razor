@page "/movies/{Id:int}"
@inject IMovieService MovieService
@inject NavigationManager Nav

<PageTitle>@(_detail?.Movie.Title ?? "Loading…") – Movielandia</PageTitle>

@if (_loading)
{
    <!-- ── Skeleton ────────────────────────────────────────────────────── -->
    <div class="max-w-7xl mx-auto px-6 py-12">
        <div class="flex flex-col md:flex-row gap-10 animate-pulse">
            <div class="w-full md:w-64 lg:w-72 shrink-0">
                <div class="aspect-[2/3] rounded-2xl bg-gray-800"></div>
            </div>
            <div class="flex-1 space-y-4 pt-2">
                <div class="h-8 bg-gray-800 rounded w-2/3"></div>
                <div class="h-4 bg-gray-800 rounded w-1/3"></div>
                <div class="flex gap-2 mt-4">
                    @for (var i = 0; i < 3; i++) { <div class="h-6 w-16 bg-gray-800 rounded-full"></div> }
                </div>
                <div class="space-y-2 mt-4">
                    <div class="h-3 bg-gray-800 rounded w-full"></div>
                    <div class="h-3 bg-gray-800 rounded w-5/6"></div>
                    <div class="h-3 bg-gray-800 rounded w-4/6"></div>
                </div>
            </div>
        </div>
    </div>
}
else if (_detail is null)
{
    <!-- ── Not found ──────────────────────────────────────────────────── -->
    <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-6">
        <p class="text-9xl font-black text-amber-500/10 select-none leading-none">404</p>
        <h1 class="text-2xl font-bold text-white -mt-2">Movie not found</h1>
        <p class="text-gray-500 mt-2 mb-8 text-sm">This movie doesn't exist or was removed.</p>
        <a href="/movies"
           class="bg-amber-500 hover:bg-amber-400 text-black font-bold px-6 py-3 rounded-full transition-all">
            ← Back to Movies
        </a>
    </div>
}
else
{
    var movie  = _detail.Movie;
    var stats  = _detail.Stats;

    <!-- ── Hero banner ────────────────────────────────────────────────── -->
    <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-b from-gray-900/0 via-gray-950/60 to-gray-950 pointer-events-none z-10"></div>
        @if (!string.IsNullOrEmpty(movie.PhotoSrcProd))
        {
            <img src="@movie.PhotoSrcProd"
                 alt=""
                 class="w-full h-56 md:h-80 object-cover object-top opacity-30 blur-sm"
                 aria-hidden="true"
                 onerror="this.style.display='none'" />
        }
        else
        {
            <div class="w-full h-32"></div>
        }
    </div>

    <!-- ── Main content ───────────────────────────────────────────────── -->
    <div class="max-w-7xl mx-auto px-6 -mt-20 relative z-20 pb-20">

        <!-- Back link -->
        <a href="/movies"
           class="inline-flex items-center gap-2 text-gray-500 hover:text-gray-300 text-sm mb-8 transition-colors">
            ← Back to Movies
        </a>

        <!-- Poster + Info row -->
        <div class="flex flex-col md:flex-row gap-8 lg:gap-12">

            <!-- Poster -->
            <div class="shrink-0 w-48 md:w-56 lg:w-64 mx-auto md:mx-0">
                <div class="rounded-2xl overflow-hidden ring-2 ring-gray-700/60 shadow-2xl shadow-black/60">
                    <img src="@movie.PhotoSrc"
                         alt="@movie.Title poster"
                         class="w-full aspect-[2/3] object-cover"
                         onerror="this.src='https://placehold.co/300x450/1f2937/4b5563?text=No+Poster'" />
                </div>
            </div>

            <!-- Info panel -->
            <div class="flex-1 min-w-0">
                <h1 class="text-3xl md:text-4xl font-black text-white leading-tight">@movie.Title</h1>

                <!-- Meta row -->
                <div class="flex flex-wrap items-center gap-3 mt-3 text-sm text-gray-400">
                    @if (movie.DateAired.HasValue)
                    {
                        <span>@movie.DateAired.Value.Year</span>
                        <span class="text-gray-700">·</span>
                    }
                    @if (movie.Duration > 0)
                    {
                        <span>@movie.Duration min</span>
                        <span class="text-gray-700">·</span>
                    }
                    @if (movie.RatingImdb > 0)
                    {
                        <span class="flex items-center gap-1 text-amber-400 font-semibold">
                            ★ @movie.RatingImdb.ToString("F1") IMDb
                        </span>
                    }
                    @if (stats.AverageRating > 0)
                    {
                        <span class="text-gray-700">·</span>
                        <span class="flex items-center gap-1 text-blue-400 font-semibold">
                            ⭐ @stats.AverageRating.ToString("F1") user
                        </span>
                    }
                </div>

                <!-- Genres -->
                @if (movie.Genres.Any())
                {
                    <div class="flex flex-wrap gap-2 mt-4">
                        @foreach (var genre in movie.Genres)
                        {
                            <span class="bg-amber-500/10 border border-amber-500/20 text-amber-400
                                         text-xs font-medium px-3 py-1 rounded-full">
                                @genre.Name
                            </span>
                        }
                    </div>
                }

                <!-- Stats -->
                <div class="flex flex-wrap gap-6 mt-6 text-center">
                    <div class="bg-gray-800/60 border border-gray-700/40 rounded-xl px-5 py-3">
                        <p class="text-2xl font-black text-white">@stats.TotalReviews</p>
                        <p class="text-gray-500 text-xs mt-0.5">Reviews</p>
                    </div>
                    @if (stats.BookmarksCount > 0)
                    {
                        <div class="bg-gray-800/60 border border-gray-700/40 rounded-xl px-5 py-3">
                            <p class="text-2xl font-black text-white">@stats.BookmarksCount</p>
                            <p class="text-gray-500 text-xs mt-0.5">Bookmarks</p>
                        </div>
                    }
                    @if (stats.SimilarMovies.Any())
                    {
                        <div class="bg-gray-800/60 border border-gray-700/40 rounded-xl px-5 py-3">
                            <p class="text-2xl font-black text-white">@stats.SimilarMovies.Count()</p>
                            <p class="text-gray-500 text-xs mt-0.5">Related films</p>
                        </div>
                    }
                </div>

                <!-- Trailer -->
                @if (!string.IsNullOrEmpty(movie.TrailerSrc))
                {
                    <a href="@movie.TrailerSrc" target="_blank" rel="noopener noreferrer"
                       class="inline-flex items-center gap-2 mt-6 bg-red-600/90 hover:bg-red-500 active:scale-95
                              text-white font-semibold px-5 py-2.5 rounded-full transition-all duration-200">
                        ▶ Watch Trailer
                    </a>
                }

                <!-- Description -->
                @if (!string.IsNullOrEmpty(movie.Description))
                {
                    <p class="mt-6 text-gray-400 leading-relaxed text-[15px] max-w-2xl">
                        @movie.Description
                    </p>
                }
            </div>
        </div>

        <!-- ── Cast ──────────────────────────────────────────────────────── -->
        @if (movie.Cast.Any())
        {
            <section class="mt-16">
                <h2 class="text-xl font-bold text-white mb-6">Cast</h2>
                <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-4">
                    @foreach (var actor in movie.Cast.Take(8))
                    {
                        <div class="flex flex-col items-center text-center gap-2">
                            <div class="w-16 h-16 rounded-full overflow-hidden ring-2 ring-gray-700/60 bg-gray-800">
                                <img src="@actor.PhotoSrc"
                                     alt="@actor.Fullname"
                                     class="w-full h-full object-cover"
                                     onerror="this.src='https://placehold.co/64x64/1f2937/6b7280?text=?'" />
                            </div>
                            <p class="text-gray-300 text-xs font-medium leading-tight">@actor.Fullname</p>
                        </div>
                    }
                </div>
            </section>
        }

        <!-- ── Crew ──────────────────────────────────────────────────────── -->
        @if (movie.Crew.Any())
        {
            <section class="mt-12">
                <h2 class="text-xl font-bold text-white mb-6">Crew</h2>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
                    @foreach (var member in movie.Crew.Take(8))
                    {
                        <div class="flex items-center gap-3 bg-gray-800/50 border border-gray-700/40 rounded-xl p-3">
                            <img src="@member.PhotoSrc"
                                 alt="@member.Fullname"
                                 class="w-10 h-10 rounded-full object-cover bg-gray-700 shrink-0"
                                 onerror="this.src='https://placehold.co/40x40/1f2937/6b7280?text=?'" />
                            <div class="min-w-0">
                                <p class="text-gray-200 text-sm font-medium truncate">@member.Fullname</p>
                                <p class="text-gray-500 text-xs truncate">@member.Role</p>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

        <!-- ── Reviews ───────────────────────────────────────────────────── -->
        @if (movie.Reviews.Any())
        {
            <section class="mt-12">
                <h2 class="text-xl font-bold text-white mb-6">
                    Reviews
                    <span class="text-gray-600 font-normal text-base ml-2">(@stats.TotalReviews)</span>
                </h2>

                <div class="space-y-4">
                    @foreach (var review in movie.Reviews.Take(5))
                    {
                        <article class="bg-gray-800/40 border border-gray-700/40 rounded-2xl p-5">
                            <div class="flex items-center justify-between gap-4 flex-wrap">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-amber-500/20 flex items-center justify-center
                                                text-amber-400 font-bold text-sm shrink-0">
                                        @review.UserName[..1].ToUpperInvariant()
                                    </div>
                                    <div>
                                        <p class="text-gray-200 text-sm font-semibold">@review.UserName</p>
                                        <p class="text-gray-600 text-xs">@review.CreatedAt.ToString("MMM d, yyyy")</p>
                                    </div>
                                </div>
                                @if (review.Rating.HasValue)
                                {
                                    <span class="bg-amber-500/15 text-amber-400 text-xs font-bold px-2.5 py-1 rounded-full">
                                        ★ @review.Rating.Value.ToString("F1")
                                    </span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(review.Content))
                            {
                                <p class="text-gray-400 text-sm leading-relaxed mt-3">@review.Content</p>
                            }
                            <!-- Votes -->
                            @if (review.UpvotesCount > 0 || review.DownvotesCount > 0)
                            {
                                <div class="flex items-center gap-4 mt-3 text-xs text-gray-600">
                                    <span>👍 @review.UpvotesCount</span>
                                    <span>👎 @review.DownvotesCount</span>
                                </div>
                            }
                        </article>
                    }
                </div>
            </section>
        }

        <!-- ── Similar Movies ─────────────────────────────────────────────── -->
        @if (stats.SimilarMovies.Any())
        {
            <section class="mt-16">
                <h2 class="text-xl font-bold text-white mb-6">You Might Also Like</h2>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
                    @foreach (var similar in stats.SimilarMovies.Take(6))
                    {
                        <MovieCard Movie="similar" />
                    }
                </div>
            </section>
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private MovieDetailResponse? _detail;
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _detail = null;

        try
        {
            _detail = await MovieService.GetByIdAsync(Id, new MovieQueryParams());
        }
        catch
        {
            _detail = null;
        }
        finally
        {
            _loading = false;
        }
    }
}
