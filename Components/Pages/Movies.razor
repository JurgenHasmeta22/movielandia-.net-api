@page "/movies"
@inject IMovieService MovieService
@implements IDisposable

<PageTitle>Movies – Movielandia</PageTitle>

<div class="max-w-7xl mx-auto px-6 py-10">

    <!-- ── Page header ──────────────────────────────────────────────────── -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-white">Movies</h1>
        @if (_result != null)
        {
            <p class="text-gray-500 text-sm mt-1">@_result.TotalCount.ToString("N0") titles</p>
        }
    </div>

    <!-- ── Controls ─────────────────────────────────────────────────────── -->
    <div class="flex flex-col sm:flex-row gap-3 mb-8">
        <!-- Search -->
        <div class="relative flex-1">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm pointer-events-none">🔍</span>
            <input type="text"
                   placeholder="Search movies…"
                   value="@_title"
                   @oninput="OnSearchInput"
                   class="w-full bg-gray-800 border border-gray-700 focus:border-amber-500/70
                          text-white placeholder-gray-500 rounded-xl pl-10 pr-4 py-3
                          outline-none transition-colors text-sm" />
        </div>

        <!-- Sort field -->
        <select @bind="_sortBy" @bind:after="ReloadMovies"
                class="bg-gray-800 border border-gray-700 focus:border-amber-500/70 text-gray-300
                       rounded-xl px-4 py-3 outline-none transition-colors text-sm cursor-pointer min-w-[160px]">
            <option value="title">A–Z Title</option>
            <option value="ratingImdb">⭐ Rating</option>
            <option value="dateAired">📅 Release Date</option>
            <option value="duration">⏱ Duration</option>
        </select>

        <!-- Sort direction -->
        <select @bind="_ascOrDesc" @bind:after="ReloadMovies"
                class="bg-gray-800 border border-gray-700 focus:border-amber-500/70 text-gray-300
                       rounded-xl px-4 py-3 outline-none transition-colors text-sm cursor-pointer">
            <option value="asc">↑ Ascending</option>
            <option value="desc">↓ Descending</option>
        </select>
    </div>

    <!-- ── Grid / States ─────────────────────────────────────────────────── -->
    @if (_loading)
    {
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
            @for (var i = 0; i < PageSize; i++)
            {
                <div class="rounded-xl bg-gray-800/50 overflow-hidden">
                    <div class="aspect-[2/3] bg-gray-700/60 animate-pulse"></div>
                    <div class="p-3 space-y-2">
                        <div class="h-3 bg-gray-700/60 rounded animate-pulse w-3/4"></div>
                        <div class="h-2 bg-gray-700/60 rounded animate-pulse w-1/2"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (_result?.Items.Any() == true)
    {
        <!-- Movie grid -->
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 animate-fade-in">
            @foreach (var movie in _result.Items)
            {
                <MovieCard Movie="movie" />
            }
        </div>

        <!-- ── Pagination ────────────────────────────────────────────────── -->
        @if (_result.TotalPages > 1)
        {
            <div class="flex items-center justify-center gap-2 mt-12 flex-wrap">
                <button @onclick="() => GoToPage(_currentPage - 1)"
                        disabled="@(!_result.HasPreviousPage)"
                        class="px-4 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm font-medium
                               disabled:opacity-30 disabled:cursor-not-allowed
                               hover:border-amber-500/60 hover:text-amber-400 transition-all">
                    ← Prev
                </button>

                @for (var p = Math.Max(1, _currentPage - 2); p <= Math.Min(_result.TotalPages, _currentPage + 2); p++)
                {
                    var pageNum = p;
                    var isCurrent = pageNum == _currentPage;
                    <button @onclick="() => GoToPage(pageNum)"
                            class="@(isCurrent
                                ? "px-4 py-2 rounded-lg bg-amber-500 text-black text-sm font-bold"
                                : "px-4 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm font-medium hover:border-amber-500/60 hover:text-amber-400 transition-all")">
                        @pageNum
                    </button>
                }

                <button @onclick="() => GoToPage(_currentPage + 1)"
                        disabled="@(!_result.HasNextPage)"
                        class="px-4 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm font-medium
                               disabled:opacity-30 disabled:cursor-not-allowed
                               hover:border-amber-500/60 hover:text-amber-400 transition-all">
                    Next →
                </button>
            </div>

            <p class="text-center text-gray-600 text-xs mt-3">
                Page @_currentPage of @_result.TotalPages
            </p>
        }
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-24 text-center">
            <span class="text-5xl mb-4">🎬</span>
            <p class="text-gray-400 font-medium">No movies found</p>
            <p class="text-gray-600 text-sm mt-1">Try a different search term or clear the filters.</p>
            <button @onclick="ClearFilters"
                    class="mt-6 px-5 py-2 bg-gray-800 hover:bg-gray-700 border border-gray-700
                           rounded-lg text-sm text-gray-300 transition-all">
                Clear filters
            </button>
        </div>
    }
</div>

@code {
    private const int PageSize = 12;

    private PagedResult<MovieDto>? _result;
    private bool _loading = true;
    private int _currentPage = 1;
    private string _sortBy = "title";
    private string _ascOrDesc = "asc";
    private string? _title;
    private CancellationTokenSource? _searchCts;

    protected override async Task OnInitializedAsync() => await LoadMovies();

    private async Task LoadMovies()
    {
        _loading = true;
        StateHasChanged();

        _result = await MovieService.GetPagedAsync(new MovieFilterParams
        {
            Page = _currentPage,
            PageSize = PageSize,
            SortBy = _sortBy,
            AscOrDesc = _ascOrDesc,
            Title = _title,
        });

        _loading = false;
    }

    private async Task ReloadMovies()
    {
        _currentPage = 1;
        await LoadMovies();
    }

    private async void OnSearchInput(ChangeEventArgs e)
    {
        _title = e.Value?.ToString();

        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(350, token);
            _currentPage = 1;
            await LoadMovies();
        }
        catch (TaskCanceledException) { }
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || (_result != null && page > _result.TotalPages)) return;
        _currentPage = page;
        await LoadMovies();
    }

    private async Task ClearFilters()
    {
        _title = null;
        _sortBy = "title";
        _ascOrDesc = "asc";
        await ReloadMovies();
    }

    public void Dispose() => _searchCts?.Dispose();
}
